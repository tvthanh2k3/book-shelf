*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
.env/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# MyPy
.mypy_cache/

# Alembic (keep migrations, ignore generated env artefacts)
# alembic/versions/ is intentionally tracked

